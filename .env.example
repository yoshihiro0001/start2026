# Evolution Factory environment variables template
# Do not put real secrets in this file.
# Values stay empty here.

# Supabase client-side values.
# Use publishable key if available. Legacy anon key may be used only after RLS/public exposure is confirmed.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only. Never expose in browser code. Never commit real values.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
