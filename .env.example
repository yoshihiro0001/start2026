# Evolution Factory environment variables template
# Do not put real secrets in this file.
# Values stay empty here.

# Supabase client-side values.
# Use the Supabase publishable key. If the dashboard still shows only a legacy anon public key,
# put that value into NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY during the migration period.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-side only. Never expose in browser code. Never commit real values.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
